{
    "name": "mccheng-personal-page",
    "version": "1.0.0",
    "description": "McCheng Personal Page",
    "main": "index.js",
    "scripts": {
        "start:tailwind": "cross-env NODE_ENV=development tailwindcss --postcss -i css/tailwind.css -o css/tailwind-runtime.css -w",
        "build:tailwind": "cross-env NODE_ENV=production tailwindcss --postcss -i css/tailwind.css -o css/tailwind-build.css --minify",
        "test": "echo \"Error: no test specified\" && exit 1",
        "lint": "eslint js/**/*.js",
        "lint:fix": "eslint js/**/*.js --fix",
        "format": "prettier --write \"**/*.{js,html,css,json}\"",
        "prepare": "husky",
        "images": "node scripts/optimize-images.mjs",
        "images:clean": "node scripts/optimize-images.mjs --clean"
    },
    "keywords": [],
    "author": "McCheng",
    "license": "MIT",
    "devDependencies": {
        "autoprefixer": "^10.4.27",
        "cross-env": "^10.1.0",
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sharp": "^0.33.0",
        "tailwindcss": "^3.4.18"
    },
    "dependencies": {
        "postcss": "^8.4.33",
        "postcss-simple-vars": "^7.0.1"
    }
}
